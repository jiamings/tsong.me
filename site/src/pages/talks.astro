---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const talks = (await getCollection("talks")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Talks | Jiaming Song">
  <section class="hero">
    <h1>Talks</h1>
    <p>Invited talks, tutorials, and technical sessions.</p>
  </section>

  <section class="cards">
    {
      talks.map((talk) => (
        <article class="card">
          <h3>{talk.data.title}</h3>
          <p class="meta">
            {talk.data.event} - {talk.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short" })}
          </p>
          <p>{talk.data.summary}</p>
          <p class="meta">{talk.data.location ?? "Location unavailable"}</p>
          <p>
            {talk.data.slidesUrl && (
              <a href={talk.data.slidesUrl} target="_blank" rel="noreferrer">Slides</a>
            )}
            {talk.data.slidesUrl && talk.data.videoUrl && " | "}
            {talk.data.videoUrl && (
              <a href={talk.data.videoUrl} target="_blank" rel="noreferrer">Video</a>
            )}
          </p>
        </article>
      ))
    }
  </section>
</Layout>
